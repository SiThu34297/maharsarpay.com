# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://maharsarpay.com
AUTH_TRUST_HOST=true
# Optional compatibility alias used by some Auth.js/NextAuth setups
NEXTAUTH_URL=$AUTH_URL

# Optional Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Demo credentials for email/password login (optional)
# If not set, fallback demo user is reader@maharsarpay.com / demo1234
AUTH_DEMO_EMAIL=
AUTH_DEMO_PASSWORD=
AUTH_DEMO_NAME=
AUTH_DEMO_USER_ID=
AUTH_DEMO_IMAGE=

# Backend API
BOOK_API_BASE_URL=https://bookapi.sabahna.com

# Google reCAPTCHA v3
# Public site key used by browser forms in this app
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key should be configured in backend API service where verification happens
# RECAPTCHA_SECRET_KEY=

# Canonical website URL used for SEO metadata
NEXT_PUBLIC_SITE_URL=https://maharsarpay.com
